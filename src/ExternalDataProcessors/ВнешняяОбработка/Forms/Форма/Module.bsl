КонецФункции

&НаСервере
Функция ПолучитьПоследнийСтатус(ДокументСсылка)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ИсторияСтатусовДокументов.Статус КАК Статус
	|ИЗ
	|	РегистрСведений.ИсторияСтатусовДокументов КАК ИсторияСтатусовДокументов
	|ГДЕ
	|	ИсторияСтатусовДокументов.Документ = &Документ
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаЗаписи УБЫВ";
	
	Запрос.УстановитьПараметр("Документ", ДокументСсылка);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Статус;    
		
	КонецЕсли;
	
	Возврат Перечисления.СтатусыДокументов.ПустаяСсылка();
	
КонецФункции

&НаСервере
Функция ИсключитьВедомостьПоДате(Ведомость, ДатаОтправкиРешения)
	
	ДеньОтправки = День(ДатаОтправкиРешения);
	ДеньВедомости = День(Ведомость.Дата);
	МесяцВедомости = Месяц(Ведомость.Дата);
	
	Если ДеньОтправки >= 1 И ДеньОтправки <= 10 Тогда
		Возврат ДеньВедомости = День(ТекущаяДатаСеанса());
		
	ИначеЕсли ДеньОтправки >= 11 И ДеньОтправки <= 20 Тогда
		Возврат ДеньВедомости % 2 = 0;   
		
	Иначе                          
		Возврат МесяцВедомости % 2 <> 0;    
		
	КонецЕсли;
	
КонецФункции

&НаСервере
Функция ПолучитьКоличествоДоговоров(Ведомость)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	КОЛИЧЕСТВО(ВедомостьДоговор.Ссылка) КАК КоличествоДоговоров
	|ИЗ
	|	Документ.Ведомость.Договор КАК ВедомостьДоговор
	|ГДЕ
	|	ВедомостьДоговор.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Ведомость);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.КоличествоДоговоров;
		
	КонецЕсли;
	
	Возврат 0;
	
КонецФункции

&НаСервере
Процедура НастроитьУсловноеОформлениеПрограммно()
	
	// Программное оформление только для мужского пола
	// Для женского - работает интерактивное оформление из конфигуратора
	Если ПолКандидата <> "Мужской" Тогда
		Возврат;                     
		
	КонецЕсли;
	
	УсловноеОформление.Элементы.Очистить();
	
	ЭлементОформления = УсловноеОформление.Элементы.Добавить();
	ЭлементОформления.Использование = Истина;
	
	// Условие: путь к реквизиту таблицы через точку
	ЭлементУсловия = ЭлементОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементУсловия.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("ТаблицаВедомостей.СтатусАкцептован");
	ЭлементУсловия.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
	ЭлементУсловия.ПравоеЗначение = Истина;
	
	// Оформление
	ЭлементОформления.Оформление.УстановитьЗначениеПараметра("ЦветФона", WebЦвета.СветлоЗеленый);
	
	// Поля: имена колонок на форме (БЕЗ точки!)
	ПолеОформления = ЭлементОформления.Поля.Элементы.Добавить();
	ПолеОформления.Поле = Новый ПолеКомпоновкиДанных("ТаблицаВедомостейВедомость");
	
	ПолеОформления = ЭлементОформления.Поля.Элементы.Добавить();
	ПолеОформления.Поле = Новый ПолеКомпоновкиДанных("ТаблицаВедомостейСтатусАкцептован");
	
	ПолеОформления = ЭлементОформления.Поля.Элементы.Добавить();
	ПолеОформления.Поле = Новый ПолеКомпоновкиДанных("ТаблицаВедомостейКоличествоДоговоров");
	
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Для мужского пола настраиваем программно
	// Для женского - работает интерактивное оформление из конфигуратора
	Если ПолКандидата = "Мужской" Тогда
		НастроитьУсловноеОформлениеПрограммно();   
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПолКандидатаПриИзменении(Элемент)  
	
	ПриСозданииНаСервере(Ложь, Ложь);    
	
КонецПроцедуры
