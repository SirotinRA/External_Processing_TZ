&НаКлиенте
Процедура ЗаполнитьНужное()  
	
	ЗаполнитьТаблицуВедомостейНаСервере();
	
	// Обновляем отображение таблицы для применения условного оформления
	ТекущаяСтрока = Элементы.ТаблицаВедомостей.ТекущаяСтрока;
	Элементы.ТаблицаВедомостей.ТекущаяСтрока = Неопределено;    
	
	Если ТекущаяСтрока <> Неопределено Тогда
		Элементы.ТаблицаВедомостей.ТекущаяСтрока = ТекущаяСтрока;  
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьЛишнее()
	
	УдаленныеНомера = Новый СписокЗначений;
	ИндексыУдаления = Новый Массив;
	
	Для Каждого СтрокаТЧ Из ТаблицаВедомостей Цикл 
		
		Если СтрокаТЧ.КоличествоДоговоров % 2 = 0 Тогда
			УдаленныеНомера.Добавить(Строка(СтрокаТЧ.Ведомость));
			ИндексыУдаления.Добавить(ТаблицаВедомостей.Индекс(СтрокаТЧ));
			
		КонецЕсли;     
		
	КонецЦикла;
	
	УдаленныеНомера.СортироватьПоЗначению(НаправлениеСортировки.Возр);
	
	ВерхняяГраница = ИндексыУдаления.ВГраница();  
	
	Пока ВерхняяГраница >= 0 Цикл   
		ТаблицаВедомостей.Удалить(ИндексыУдаления[ВерхняяГраница]);
		ВерхняяГраница = ВерхняяГраница - 1;                       
		
	КонецЦикла;
	
	ВывестиИнформацииОбУдалении(УдаленныеНомера); 
	
КонецПроцедуры

&НаКлиенте
Процедура ВывестиИнформацииОбУдалении(УдаленныеНомера)
	
	Если УдаленныеНомера.Количество() = 0 Тогда
		Возврат;    
		
	КонецЕсли;
	
	МассивНомеров = Новый Массив;   
	
	Для Каждого ЭлементСписка Из УдаленныеНомера Цикл
		МассивНомеров.Добавить(Строка(ЭлементСписка.Значение));
		
	КонецЦикла;
	
	СтрокаНомеров = СтрСоединить(МассивНомеров, ", ");
	ТекстСообщения = СтрШаблон("Удалено документов: %1 (%2).", УдаленныеНомера.Количество(), СтрокаНомеров);
	
	// Вывод информации в зависимости от длины фамилии кандидата
	Если ДлинаФамилииКандидата < 6 Тогда
		// Меньше 6: метод Сообщить()
		Сообщить(ТекстСообщения);
		
	ИначеЕсли ДлинаФамилииКандидата <= 7 Тогда
		// 6-7: объект СообщениеПользователю
		СообщениеПользователю = Новый СообщениеПользователю;
		СообщениеПользователю.Текст = ТекстСообщения;
		СообщениеПользователю.Сообщить();
		
	ИначеЕсли ДлинаФамилииКандидата <= 9 Тогда
		// 8-9: открытие произвольной формы "ФормаСообщения"
		ФормаСообщения = ПолучитьФорму("ВнешняяОбработка.ВнешняяОбработка.Форма.ФормаСообщения");
		ФормаСообщения.ТекстСообщения = ТекстСообщения;
		ФормаСообщения.Открыть();
		
	ИначеЕсли ДлинаФамилииКандидата <= 11 Тогда
		// 10-11: элемент основной формы
		ТекстИнформации = ТекстСообщения;
		Модифицированность = Истина;
		
	ИначеЕсли ДлинаФамилииКандидата <= 13 Тогда
		// 12-13: вызов исключения
		ВызватьИсключение ТекстСообщения;
		
	Иначе
		// Больше 13: предупреждение
		ПоказатьПредупреждение(, ТекстСообщения);    
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТаблицуВедомостейНаСервере()
	
	Если Не ЗначениеЗаполнено(СравнениеДат) ИЛИ Не ЗначениеЗаполнено(ТипДаты) Тогда
		Сообщить("Укажите параметры сравнения и тип даты");
		Возврат;                                      
		
	КонецЕсли;
	
	ТаблицаВедомостей.Очистить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Ведомость.Ссылка КАК Ведомость
	|ИЗ
	|	Документ.Ведомость КАК Ведомость
	|
	|УПОРЯДОЧИТЬ ПО
	|	Ведомость.Дата";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		// Фильтр по дате отправки решения
		ДатаОтправки = ТекущаяДатаСеанса();
		Если ИсключитьВедомостьПоДате(Выборка.Ведомость, ДатаОтправки) Тогда
			Продолжить;    
			
		КонецЕсли;
		
		ДатаПервогоАктивного = ПолучитьДатуПервогоАктивногоДоговора(Выборка.Ведомость);
		Если ДатаПервогоАктивного = Дата(1, 1, 1) Тогда
			Продолжить;
			
		КонецЕсли;
		
		МинДатаДоговора = ПолучитьМинимальнуюДатуДоговора(Выборка.Ведомость);
		МаксДатаДоговора = ПолучитьМаксимальнуюДатуДоговора(Выборка.Ведомость);
		
		НужнаяДата = ?(ТипДаты = "Минимальная", МинДатаДоговора, МаксДатаДоговора);
		
		СоответствуетУсловию = Ложь;
		Если СравнениеДат = "Равно" Тогда
			СоответствуетУсловию = ДатаПервогоАктивного = НужнаяДата; 
			
		Иначе
			СоответствуетУсловию = ДатаПервогоАктивного <> НужнаяДата;  
			
		КонецЕсли;
		
		Если СоответствуетУсловию Тогда
			НоваяСтрока = ТаблицаВедомостей.Добавить();
			НоваяСтрока.Ведомость = Выборка.Ведомость;
			НоваяСтрока.СтатусАкцептован = (ПолучитьПоследнийСтатус(Выборка.Ведомость) = Перечисления.СтатусыДокументов.Акцептован);
			НоваяСтрока.КоличествоДоговоров = ПолучитьКоличествоДоговоров(Выборка.Ведомость); 
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьДатуПервогоАктивногоДоговора(Ведомость)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВедомостьДоговор.Договор.НачалоДействия КАК ДатаДействия
	|ИЗ
	|	Документ.Ведомость.Договор КАК ВедомостьДоговор
	|ГДЕ
	|	ВедомостьДоговор.Ссылка = &Ссылка
	|	И ВедомостьДоговор.Договор.Активен = ИСТИНА
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВедомостьДоговор.НомерСтроки";
	
	Запрос.УстановитьПараметр("Ссылка", Ведомость);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.ДатаДействия;  
		
	КонецЕсли;
	
	Возврат Дата(1, 1, 1);
	
КонецФункции

&НаСервере
Функция ПолучитьМинимальнуюДатуДоговора(Ведомость)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВедомостьДоговор.Договор.НачалоДействия КАК ДатаДействия
	|ИЗ
	|	Документ.Ведомость.Договор КАК ВедомостьДоговор
	|ГДЕ
	|	ВедомостьДоговор.Ссылка = &Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаДействия ВОЗР";
	
	Запрос.УстановитьПараметр("Ссылка", Ведомость);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
